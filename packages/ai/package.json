{
	"name": "@deepseek-helmsman/ai",
	"version": "0.78.0",
	"description": "DeepSeek-only LLM API for DeepSeek Helmsman",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./openai-completions": {
			"types": "./dist/providers/openai-completions.d.ts",
			"import": "./dist/providers/openai-completions.js"
		},
		"./oauth": {
			"types": "./dist/oauth.d.ts",
			"import": "./dist/oauth.js"
		}
	},
	"bin": {
		"deepseek-helmsman-ai": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"generate-models": "bun scripts/generate-models.ts",
		"generate-image-models": "bun scripts/generate-image-models.ts",
		"build": "bun run generate-models && bun run generate-image-models && tsgo -p tsconfig.build.json",
		"test": "vitest --run"
	},
	"dependencies": {
		"openai": "6.26.0",
		"partial-json": "0.1.7",
		"typebox": "1.1.38"
	},
	"keywords": [
		"ai",
		"llm",
		"deepseek",
		"api"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Nervlet/deepseek-helmsman.git",
		"directory": "packages/ai"
	},
	"engines": {
		"bun": ">=1.3.10"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"canvas": "3.2.3",
		"vitest": "3.2.4"
	}
}
